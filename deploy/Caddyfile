# Local reverse proxy: unifies the built frontend + the API on one HTTP port,
# so a single Cloudflare Tunnel (or ngrok) can expose the whole app over HTTPS.
# TLS is terminated by the tunnel, so Caddy itself serves plain HTTP here.
#
# Run from the repo root:  caddy run --config deploy/Caddyfile
# Port can be overridden with the CADDY_PORT env var (default 8080).
:{$CADDY_PORT:8080} {
	encode gzip

	# Lightweight edge health check. Use /api/health when you need to verify
	# that FastAPI and the database path are healthy too.
	handle /health {
		respond "ok" 200
	}

	# API → FastAPI backend. handle_path strips the /api prefix, matching the
	# Vite dev proxy (so /api/health → backend /health).
	handle_path /api/* {
		reverse_proxy 127.0.0.1:8010 {
			# Stream Server-Sent Events without buffering.
			flush_interval -1
			fail_duration 30s
			max_fails 3
		}
	}

	# Everything else → the built single-page frontend.
	handle {
		root * ./frontend/dist
		try_files {path} /index.html
		file_server
	}
}
