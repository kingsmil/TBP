# Copy to .env and adjust for your environment.
# Database (PostGIS)
DATABASE_URL=postgresql://hdbmatch:hdbmatch@localhost:5432/hdbmatch
# Redis
REDIS_URL=redis://localhost:6379/0
# API
API_HOST=0.0.0.0
API_PORT=8010
# CRS constants (do not change without reading the architecture doc)
SRID_WGS84=4326
SRID_SVY21=3414
SRID_WEBMERCATOR=3857
# OneMap API token — required for live commute routing and geocoding.
# Get yours free at https://www.onemap.gov.sg/apidocs/ (sign up → API key)
ONEMAP_TOKEN=
# data.gov.sg API key — optional but recommended to avoid rate limiting.
# Get yours at https://beta.data.gov.sg/developers (Account → API Keys)
DATAGOV_API_KEY=
# LTA DataMall AccountKey - required for bus route sequences.
# Request access at https://datamall.lta.gov.sg/content/datamall/en/request-for-api.html
LTA_DATAMALL_API_KEY=
# Vercel AI Gateway — required for HomeOS AI agents (hackathon requirement).
# Get your key at https://vercel.com/ai-gateway
# LLM_MODEL defaults to google/gemini-2.0-flash; see vercel.com/ai-gateway/models for options.
AI_GATEWAY_API_KEY=
LLM_MODEL=openai/gpt-5.4-nano

# ── AWS (S3 / Bedrock / SageMaker) ───────────────────────────────────────────
# This sandbox uses AWS IAM Identity Center (SSO) — no static keys needed.
#
# One-time setup:
#   aws configure sso
#     SSO start URL : https://d-906670a91b.awsapps.com/start
#     SSO region    : us-east-1
#     Profile name  : kiro-pro
#
# Before running the backend locally:
#   aws sso login --profile kiro-pro
#
# In production (ECS) credentials come from the task IAM role automatically.
AWS_REGION=us-east-1
AWS_PROFILE=kiro-pro
# AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY are NOT needed with SSO.

# S3 bucket name (created by Terraform — see infrastructure/terraform/)
AWS_S3_BUCKET=hdb-match-data

# Bedrock model to use when LLM_PROVIDER=bedrock
# Full model ID list: https://docs.aws.amazon.com/bedrock/latest/userguide/model-ids.html
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Optional: Bedrock Access Gateway URL (enables full pydantic-ai structured output)
# Deploy the gateway: https://github.com/aws-samples/bedrock-access-gateway
AWS_BEDROCK_GATEWAY_URL=
AWS_BEDROCK_GATEWAY_KEY=

# SageMaker real-time endpoint name (created by infrastructure/sagemaker/deploy_model.py)
# Leave blank to use the local OLS forecaster fallback.
AWS_SAGEMAKER_ENDPOINT=hdb-psf-forecast

# Set to "bedrock" to route HomeOS agents through Amazon Bedrock instead of Vercel AI Gateway.
# LLM_PROVIDER=bedrock
