# Copy to .env and adjust for your environment.
# Database (PostGIS)
DATABASE_URL=postgresql://hdbmatch:hdbmatch@localhost:5432/hdbmatch
# Redis
REDIS_URL=redis://localhost:6379/0
# API
API_HOST=0.0.0.0
API_PORT=8010
# CRS constants (do not change without reading the architecture doc)
SRID_WGS84=4326
SRID_SVY21=3414
SRID_WEBMERCATOR=3857
# OneMap API token — required for live commute routing and geocoding.
# Get yours free at https://www.onemap.gov.sg/apidocs/ (sign up → API key)
ONEMAP_TOKEN=
# data.gov.sg API key — optional but recommended to avoid rate limiting.
# Get yours at https://beta.data.gov.sg/developers (Account → API Keys)
DATAGOV_API_KEY=
# LTA DataMall AccountKey - required for bus route sequences.
# Request access at https://datamall.lta.gov.sg/content/datamall/en/request-for-api.html
LTA_DATAMALL_API_KEY=
# Vercel AI Gateway — required for HomeOS AI agents (hackathon requirement).
# Get your key at https://vercel.com/ai-gateway
# LLM_MODEL defaults to google/gemini-2.0-flash; see vercel.com/ai-gateway/models for options.
AI_GATEWAY_API_KEY=
LLM_MODEL=openai/gpt-5.4-nano
